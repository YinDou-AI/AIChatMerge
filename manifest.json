        "content-scripts/enter-behavior-deepseek.js",
        "content-scripts/answer-extractor-deepseek.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
