{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0",
  "description": "Compare AI assistants side by side in one window. Send one prompt and review responses faster.",
  "default_locale": "en",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://chat.deepseek.com/*",
    "*://www.kimi.com/*",
    "*://kimi.com/*",
    "*://www.doubao.com/*",
    "*://doubao.com/*",
    "*://www.qianwen.com/*",
    "*://qianwen.com/*",
    "*://chatglm.cn/*",
    "*://yiyan.baidu.com/*",
    "*://yuanbao.tencent.com/*",
    "*://metaso.cn/*",
    "*://api.github.com/*",
    "*://raw.githubusercontent.com/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://grok.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "__MSG_actionDefaultTitle__"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open AIChatMerge"
    },
    "open-prompt-library": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "__MSG_commandOpenPromptLibrary__"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.qianwen.com/*",
        "https://qianwen.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-qianwen.js",
        "content-scripts/answer-extractor-qianwen.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://chatglm.cn/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-zhipu.js",
        "content-scripts/answer-extractor-zhipu.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://yiyan.baidu.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-wenxin.js",
        "content-scripts/answer-extractor-wenxin.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://yuanbao.tencent.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-yuanbao.js",
        "content-scripts/answer-extractor-yuanbao.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://metaso.cn/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-metaso.js",
        "content-scripts/answer-extractor-metaso.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-deepseek.js",
        "content-scripts/answer-extractor-deepseek.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.kimi.com/*",
        "https://kimi.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-kimi.js",
        "content-scripts/answer-extractor-kimi.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-doubao.js",
        "content-scripts/answer-extractor-doubao.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-chatgpt.js",
        "content-scripts/answer-extractor-chatgpt.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-gemini.js",
        "content-scripts/answer-extractor-gemini.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-claude.js",
        "content-scripts/answer-extractor-claude.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://grok.com/*"],
      "js": [
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-grok.js",
        "content-scripts/answer-extractor-grok.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bypass_headers",
        "enabled": true,
        "path": "rules/bypass-headers.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/prompt-libraries/default-prompts.json",
        "data/prompt-libraries/default-prompts-zh_CN.json",
        "data/prompt-libraries/custom-prompt-template.json",
        "data/prompt-libraries/guide.en.html",
        "data/prompt-libraries/guide.zh_CN.html",
        "data/prompt-libraries/guide.zh_TW.html",
        "data/prompt-libraries/guide.ko.html",
        "data/prompt-libraries/guide.ja.html",
        "data/prompt-libraries/guide.es.html",
        "data/prompt-libraries/guide.fr.html",
        "data/prompt-libraries/guide.de.html",
        "data/prompt-libraries/guide.it.html",
        "data/prompt-libraries/guide.ru.html",
        "data/version-info.json",
        "_locales/en/messages.json",
        "_locales/zh_CN/messages.json",
        "_locales/zh_TW/messages.json",
        "multi-panel/multi-panel.html",
        "multi-panel/multi-panel.js",
        "multi-panel/multi-panel.css",
        "sse-detect.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
