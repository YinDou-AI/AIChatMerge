      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bypass_headers",
        "enabled": true,
        "path": "rules/bypass-headers.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "aichatmerge-panel/multi-panel.html",
        "aichatmerge-panel/multi-panel.js",
        "aichatmerge-panel/multi-panel.css",
        "sse-detect.js"
      ],
      "matches": [
        "*://chat.deepseek.com/*",
        "*://www.kimi.com/*",
        "*://kimi.com/*",
        "*://www.doubao.com/*",
        "*://doubao.com/*",
        "*://www.qianwen.com/*",
        "*://qianwen.com/*",
        "*://chatglm.cn/*",
        "*://chat.baidu.com/*",
        "*://yuanbao.tencent.com/*",
        "*://metaso.cn/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*",
        "*://grok.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
