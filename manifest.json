{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "AIChatMerge",
  "version": "1.0.1",
  "description": "Compare AI responses side by side, merge useful answers, manage prompts, and export results.",
  "default_locale": "en",
  "permissions": [
    "storage",
    "contextMenus",
    "downloads",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://chat.deepseek.com/*",
    "*://www.kimi.com/*",
    "*://kimi.com/*",
    "*://www.doubao.com/*",
    "*://doubao.com/*",
    "*://www.qianwen.com/*",
    "*://qianwen.com/*",
    "*://chatglm.cn/*",
    "*://chat.baidu.com/*",
    "*://yuanbao.tencent.com/*",
    "*://metaso.cn/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://claude.ai/*",
    "*://grok.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "__MSG_actionDefaultTitle__"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "__MSG_commandOpenAIChatMerge__"
    },
    "open-prompt-library": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "__MSG_commandOpenPromptLibrary__"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.qianwen.com/*",
        "https://qianwen.com/*"
      ],
      "js": [
        "content-scripts/provider-detector.js",
        "content-scripts/sse-completion-policy.js",
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/send-button-finder.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-qianwen.js",
        "content-scripts/answer-extractor-qianwen.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://chatglm.cn/*"
      ],
      "js": [
        "content-scripts/provider-detector.js",
        "content-scripts/sse-completion-policy.js",
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/send-button-finder.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-zhipu.js",
        "content-scripts/answer-extractor-zhipu.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://chat.baidu.com/*"
      ],
      "js": [
        "content-scripts/provider-detector.js",
        "content-scripts/sse-completion-policy.js",
        "content-scripts/sse-bridge.js",
        "content-scripts/button-finder-utils.js",
        "content-scripts/send-button-finder.js",
        "content-scripts/enter-behavior-utils.js",
        "content-scripts/enter-behavior-wenxin.js",
        "content-scripts/answer-extractor-wenxin.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://yuanbao.tencent.com/*"
