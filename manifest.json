        "content-scripts/enter-behavior-yuanbao.js",
        "content-scripts/answer-extractor-yuanbao.js",
        "content-scripts/text-injection-all-providers.js",
        "content-scripts/focus-toggle.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
